# =============================================================
# AURA — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================

# Required for Image Analysis mode when using OpenAI models (e.g. GPT-5.2)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Ollama host — points to the Ollama service inside Docker Compose.
# If running locally without Docker, use http://localhost:11434
OLLAMA_HOST=http://ollama:11434
